@model JobSeekerDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_DashboardLayout";
}

<div class="page-head">
    <div>
        <h1>Welcome back 👋</h1>
        <p class="muted">Here's a snapshot of your job search.</p>
    </div>
    <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary">Browse jobs</a>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
        <div>
            <div class="stat-v">@Model.TotalApplications</div>
            <div class="stat-k">Total applications</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg></div>
        <div>
            <div class="stat-v">@Model.UnderReview</div>
            <div class="stat-k">In review</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <div>
            <div class="stat-v">@Model.Interviews</div>
            <div class="stat-k">Interviews</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg></div>
        <div>
            <div class="stat-v">@Model.SavedJobsCount</div>
            <div class="stat-k">Saved jobs</div>
        </div>
    </div>
</div>

<div class="dash-grid">
    <div class="card">
        <div class="card-head">
            <h3>Recent applications</h3>
            <a asp-action="Applications" class="link">View all →</a>
        </div>
        @if (!Model.RecentApplications.Any())
        {
            <div class="empty-inline">You haven't applied to any jobs yet. <a asp-controller="Jobs" asp-action="Index">Find your first role</a>.</div>
        }
        else
        {
            <table class="table">
                <thead><tr><th>Job</th><th>Company</th><th>Status</th><th>Date</th></tr></thead>
                <tbody>
                    @foreach (var a in Model.RecentApplications)
                    {
                        <tr>
                            <td>@a.Job?.Title</td>
                            <td>@a.Job?.Company?.Name</td>
                            <td><span class="status-pill status-@a.Status.ToString().ToLower()">@a.Status</span></td>
                            <td class="muted">@a.AppliedAt.ToString("dd MMM")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="card">
        <div class="card-head">
            <h3>Recommended for you</h3>
            <a asp-controller="Jobs" asp-action="Index" class="link">Explore →</a>
        </div>
        @if (!Model.RecommendedJobs.Any())
        {
            <div class="empty-inline">No jobs yet. Check back soon.</div>
        }
        else
        {
            <div class="mini-jobs">
                @foreach (var job in Model.RecommendedJobs)
                {
                    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="mini-job">
                        <div class="jc-logo">@((job.Company?.Name ?? "SJ").Substring(0, Math.Min(2, (job.Company?.Name ?? "SJ").Length)).ToUpper())</div>
                        <div>
                            <div class="mj-title">@job.Title</div>
                            <div class="muted">@job.Company?.Name · @(job.City?.Name ?? "Jordan")</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

@if (Model.Profile == null)
{
    <div class="card alert-card">
        <div>
            <h4>Complete your profile</h4>
            <p>Employers can find you faster when your profile is complete. Add your headline, CV and skills.</p>
        </div>
        <a asp-action="Profile" class="btn btn-primary">Complete profile</a>
    </div>
}
