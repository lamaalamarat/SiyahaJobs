@model JobSeekerProfileEditorViewModel
@{
    ViewData["Title"] = "My profile";
    Layout = "_DashboardLayout";
}

<div class="page-head">
    <div>
        <h1>My profile</h1>
        <p class="muted">Your information is visible to employers when you apply.</p>
    </div>
</div>

<form asp-action="Profile" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="form-errors"></div>

    <div class="card">
        <h3>Personal info</h3>
        <div class="form-grid form-grid-2">
            <div class="form-field">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" />
            </div>

            <div class="form-field">
                <label asp-for="AvatarFile"></label>
                <input asp-for="AvatarFile" type="file" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.ExistingAvatarPath))
                {
                    <div class="thumb-preview"><img src="@Model.ExistingAvatarPath" alt="avatar" /></div>
                }
            </div>

            <div class="form-field">
                <label asp-for="DateOfBirth"></label>
                <input asp-for="DateOfBirth" type="date" />
            </div>

            <div class="form-field">
                <label asp-for="Gender"></label>
                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()"></select>
            </div>

            <div class="form-field">
                <label asp-for="Nationality"></label>
                <input asp-for="Nationality" />
            </div>

            <div class="form-field">
                <label asp-for="CityId"></label>
                <select asp-for="CityId" asp-items="Model.Cities">
                    <option value="">Select city</option>
                </select>
            </div>

            <div class="form-field">
                <label asp-for="Address"></label>
                <input asp-for="Address" />
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Professional info</h3>
        <div class="form-grid form-grid-2">
            <div class="form-field full">
                <label asp-for="Headline"></label>
                <input asp-for="Headline" placeholder="e.g. Hotel Front Office Manager with 5+ years experience" />
            </div>
            <div class="form-field full">
                <label asp-for="Summary"></label>
                <textarea asp-for="Summary" rows="4"></textarea>
            </div>
            <div class="form-field">
                <label asp-for="CurrentPosition"></label>
                <input asp-for="CurrentPosition" />
            </div>
            <div class="form-field">
                <label asp-for="YearsOfExperience"></label>
                <input asp-for="YearsOfExperience" type="number" min="0" max="60" />
            </div>
            <div class="form-field">
                <label asp-for="ExperienceLevel"></label>
                <select asp-for="ExperienceLevel" asp-items="Html.GetEnumSelectList<ExperienceLevel>()"></select>
            </div>
            <div class="form-field">
                <label asp-for="Education"></label>
                <input asp-for="Education" />
            </div>
            <div class="form-field full">
                <label asp-for="Skills"></label>
                <input asp-for="Skills" placeholder="Customer service, Front office, Reservations, English" />
            </div>
            <div class="form-field full">
                <label asp-for="Languages"></label>
                <input asp-for="Languages" placeholder="Arabic, English, French" />
            </div>
            <div class="form-field">
                <label asp-for="LinkedInUrl"></label>
                <input asp-for="LinkedInUrl" />
            </div>
            <div class="form-field">
                <label asp-for="PortfolioUrl"></label>
                <input asp-for="PortfolioUrl" />
            </div>
            <div class="form-field">
                <label asp-for="ExpectedSalary"></label>
                <input asp-for="ExpectedSalary" type="number" step="0.01" />
            </div>
            <div class="form-field check">
                <label>
                    <input asp-for="OpenToWork" type="checkbox" />
                    <span>@Html.DisplayNameFor(m => m.OpenToWork)</span>
                </label>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>CV</h3>
        <div class="form-field">
            <label asp-for="CvFile"></label>
            <input asp-for="CvFile" type="file" accept=".pdf,.doc,.docx" />
            @if (!string.IsNullOrEmpty(Model.ExistingCvPath))
            {
                <div class="muted" style="margin-top:8px;">
                    Current CV: <a href="@Model.ExistingCvPath" target="_blank" rel="noopener">View</a>
                </div>
            }
            <span class="muted">PDF, DOC or DOCX (up to 5 MB).</span>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save profile</button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
