@model EmployerDashboardViewModel
@{
    ViewData["Title"] = "Employer dashboard";
    Layout = "_DashboardLayout";
    var chartLabels = string.Join(",", Model.ApplicationsPerMonth.Select(p => $"\"{p.Label}\""));
    var chartValues = string.Join(",", Model.ApplicationsPerMonth.Select(p => p.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)));
}

<div class="page-head">
    <div>
        <h1>@((Model.Company?.Name ?? "Employer") + " dashboard")</h1>
        <p class="muted">Manage your hiring pipeline end-to-end.</p>
    </div>
    <a asp-action="CreateJob" class="btn btn-primary">+ Post new job</a>
</div>

@if (Model.Company == null)
{
    <div class="card alert-card">
        <div>
            <h4>Finish your company profile</h4>
            <p>You need to set up your company profile before posting jobs.</p>
        </div>
        <a asp-action="Company" class="btn btn-primary">Set up company</a>
    </div>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg></div>
        <div><div class="stat-v">@Model.TotalJobs</div><div class="stat-k">Total jobs</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><div class="stat-v">@Model.ActiveJobs</div><div class="stat-k">Active jobs</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
        <div><div class="stat-v">@Model.TotalApplicants</div><div class="stat-k">Total applicants</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <div><div class="stat-v">@Model.InterviewsScheduled</div><div class="stat-k">Interviews</div></div>
    </div>
</div>

<div class="dash-grid">
    <div class="card">
        <div class="card-head">
            <h3>Applications last 6 months</h3>
        </div>
        <canvas id="appsChart" height="100"></canvas>
    </div>

    <div class="card">
        <div class="card-head">
            <h3>Recent applications</h3>
            <a asp-action="Applicants" class="link">View all →</a>
        </div>
        @if (!Model.RecentApplications.Any())
        {
            <div class="empty-inline">No applications yet.</div>
        }
        else
        {
            <table class="table">
                <thead><tr><th>Candidate</th><th>Job</th><th>Status</th><th>Date</th></tr></thead>
                <tbody>
                    @foreach (var a in Model.RecentApplications)
                    {
                        <tr>
                            <td>@a.JobSeeker?.FullName</td>
                            <td>@a.Job?.Title</td>
                            <td><span class="status-pill status-@a.Status.ToString().ToLower()">@a.Status</span></td>
                            <td class="muted">@a.AppliedAt.ToString("dd MMM")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card">
    <div class="card-head">
        <h3>Recent jobs</h3>
        <a asp-action="Jobs" class="link">View all →</a>
    </div>
    @if (!Model.RecentJobs.Any())
    {
        <div class="empty-inline">No jobs posted yet.</div>
    }
    else
    {
        <table class="table">
            <thead><tr><th>Title</th><th>Status</th><th>Views</th><th>Applicants</th><th>Created</th></tr></thead>
            <tbody>
                @foreach (var j in Model.RecentJobs)
                {
                    <tr>
                        <td><a asp-controller="Jobs" asp-action="Details" asp-route-id="@j.Id">@j.Title</a></td>
                        <td><span class="status-pill status-@j.Status.ToString().ToLower()">@j.Status</span></td>
                        <td>@j.ViewsCount</td>
                        <td>@j.ApplicationsCount</td>
                        <td class="muted">@j.CreatedAt.ToString("dd MMM")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var ctx = document.getElementById('appsChart');
            if (!ctx) return;
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [@Html.Raw(chartLabels)],
                    datasets: [{
                        label: 'Applications',
                        data: [@Html.Raw(chartValues)],
                        borderColor: '#1F9E78',
                        backgroundColor: 'rgba(31,158,120,0.15)',
                        tension: 0.3,
                        fill: true,
                        borderWidth: 2,
                        pointRadius: 4
                    }]
                },
                options: { responsive: true, plugins: { legend: { display: false } } }
            });
        })();
    </script>
}
