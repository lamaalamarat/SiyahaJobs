@model JobEditorViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Post a new job" : "Edit job";
    Layout = "_DashboardLayout";
    var action = Model.Id == 0 ? "CreateJob" : "EditJob";
}
<div class="page-head">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p class="muted">Describe the role and requirements to attract the best candidates.</p>
    </div>
    <a asp-action="Jobs" class="btn btn-outline">← All jobs</a>
</div>

<form asp-action="@action" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="form-errors"></div>

    <div class="card">
        <h3>Job basics</h3>
        <div class="form-grid form-grid-2">
            <div class="form-field full">
                <label asp-for="Title"></label>
                <input asp-for="Title" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="CategoryId"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories">
                    <option value="">Select category</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="CityId"></label>
                <select asp-for="CityId" asp-items="Model.Cities">
                    <option value="">Select city</option>
                </select>
            </div>
            <div class="form-field">
                <label asp-for="JobType"></label>
                <select asp-for="JobType" asp-items="Html.GetEnumSelectList<JobType>()"></select>
            </div>
            <div class="form-field">
                <label asp-for="ExperienceLevel"></label>
                <select asp-for="ExperienceLevel" asp-items="Html.GetEnumSelectList<ExperienceLevel>()"></select>
            </div>
            <div class="form-field">
                <label asp-for="Vacancies"></label>
                <input asp-for="Vacancies" type="number" min="1" max="99" />
            </div>
            <div class="form-field">
                <label asp-for="Deadline"></label>
                <input asp-for="Deadline" type="date" />
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Compensation</h3>
        <div class="form-grid form-grid-3">
            <div class="form-field">
                <label asp-for="SalaryMin"></label>
                <input asp-for="SalaryMin" type="number" step="0.01" />
            </div>
            <div class="form-field">
                <label asp-for="SalaryMax"></label>
                <input asp-for="SalaryMax" type="number" step="0.01" />
            </div>
            <div class="form-field">
                <label asp-for="Currency"></label>
                <input asp-for="Currency" />
            </div>
            <div class="form-field check">
                <label><input asp-for="IsRemote" type="checkbox" /> @Html.DisplayNameFor(m => m.IsRemote)</label>
            </div>
            <div class="form-field check">
                <label><input asp-for="IsUrgent" type="checkbox" /> @Html.DisplayNameFor(m => m.IsUrgent)</label>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Details</h3>
        <div class="form-grid">
            <div class="form-field full">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" rows="6"></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>
            <div class="form-field full">
                <label asp-for="Responsibilities"></label>
                <textarea asp-for="Responsibilities" rows="5" placeholder="One responsibility per line"></textarea>
            </div>
            <div class="form-field full">
                <label asp-for="Requirements"></label>
                <textarea asp-for="Requirements" rows="5" placeholder="One requirement per line"></textarea>
            </div>
            <div class="form-field full">
                <label asp-for="Benefits"></label>
                <textarea asp-for="Benefits" rows="4"></textarea>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <a asp-action="Jobs" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">@(Model.Id == 0 ? "Submit for approval" : "Save changes")</button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
