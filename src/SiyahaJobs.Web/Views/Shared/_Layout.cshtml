@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var user = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
    var primaryRole = roles.FirstOrDefault();
    string dashboardUrl =
        primaryRole == RoleNames.Admin ? Url.Action("Index", "Admin")! :
        primaryRole == RoleNames.Employer ? Url.Action("Index", "Employer")! :
        primaryRole == RoleNames.JobSeeker ? Url.Action("Index", "JobSeeker")! : "#";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "SiyahaJobs.jo") — Jordan's Tourism &amp; Hospitality Career Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=Cormorant+Garamond:ital,wght@@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="nav">
        <div class="nav-inner">
            <a href="@Url.Action("Index", "Home")" class="nav-logo">
                <span class="logo-text"><span class="logo-green">Siyaha</span><span class="logo-navy">Jobs</span><span class="logo-dot">.jo</span></span>
            </a>
            <nav class="nav-links">
                <a href="@Url.Action("Index", "Jobs")">Jobs</a>
                <a href="@Url.Action("Index", "Companies")">Companies</a>
                <a href="@Url.Action("About", "Home")">About</a>
                <a href="@Url.Action("Contact", "Home")">Contact</a>
            </nav>
            <div class="nav-cta">
                @if (user != null)
                {
                    <a href="@dashboardUrl" class="btn btn-outline btn-sm">Dashboard</a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                        <button type="submit" class="btn btn-primary btn-sm">Sign out</button>
                    </form>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline btn-sm">Sign in</a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-primary btn-sm">Create account</a>
                }
                <button class="menu-toggle" aria-label="Open menu"
                        onclick="document.querySelector('.drawer').classList.add('open')">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 6h18M3 12h18M3 18h18" />
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <div class="drawer" onclick="if (event.target === this) this.classList.remove('open');">
        <div class="drawer-panel">
            <button class="drawer-close" aria-label="Close"
                    onclick="document.querySelector('.drawer').classList.remove('open')">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 6L6 18M6 6l12 12" />
                </svg>
            </button>
            <a href="@Url.Action("Index", "Home")">Home</a>
            <a href="@Url.Action("Index", "Jobs")">Jobs</a>
            <a href="@Url.Action("Index", "Companies")">Companies</a>
            <a href="@Url.Action("About", "Home")">About</a>
            <a href="@Url.Action("Contact", "Home")">Contact</a>
            <div class="drawer-cta">
                @if (user != null)
                {
                    <a href="@dashboardUrl" class="btn btn-outline">Dashboard</a>
                    <form asp-controller="Account" asp-action="Logout" method="post"><button class="btn btn-primary">Sign out</button></form>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline">Sign in</a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-primary">Create account</a>
                }
            </div>
        </div>
    </div>

    <partial name="_ToastPartial" />

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="logo-text footer-logo">
                        <span class="logo-green">Siyaha</span><span class="logo-navy">Jobs</span><span class="logo-dot">.jo</span>
                    </div>
                    <p>Jordan's dedicated career platform for tourism, hospitality, and travel professionals.</p>
                    <div class="social">
                        <a href="#" aria-label="Facebook"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 10-11.6 9.9V15h-2.5v-3h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6v1.9h2.8l-.5 3h-2.4V22A10 10 0 0022 12z"/></svg></a>
                        <a href="#" aria-label="Instagram"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.4a4 4 0 11-7.9 1 4 4 0 017.9-1zM17.5 6.5h0"/></svg></a>
                        <a href="#" aria-label="LinkedIn"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 2a2 2 0 110 4 2 2 0 010-4z"/></svg></a>
                    </div>
                </div>
                <div>
                    <h5>Candidates</h5>
                    <ul>
                        <li><a href="@Url.Action("Index", "Jobs")">Browse jobs</a></li>
                        <li><a href="@Url.Action("Index", "Companies")">Companies</a></li>
                        <li><a href="@Url.Action("Register", "Account")">Create account</a></li>
                    </ul>
                </div>
                <div>
                    <h5>Employers</h5>
                    <ul>
                        <li><a href="@Url.Action("Register", "Account")">Post a job</a></li>
                        <li><a href="@Url.Action("Login", "Account")">Employer login</a></li>
                    </ul>
                </div>
                <div>
                    <h5>Company</h5>
                    <ul>
                        <li><a href="@Url.Action("About", "Home")">About</a></li>
                        <li><a href="@Url.Action("Contact", "Home")">Contact</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>© @DateTime.Now.Year SiyahaJobs.jo — A registered Jordanian platform.</span>
                <div class="footer-legal">
                    <a href="#">Privacy</a>
                    <a href="#">Terms</a>
                    <a href="#">Cookies</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
