@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}
<section class="auth-wrap">
    <div class="auth-card">
        <a asp-controller="Home" asp-action="Index" class="auth-logo">
            <span class="logo-green">Siyaha</span><span class="logo-navy">Jobs</span><span class="logo-dot">.jo</span>
        </a>
        <h1>Reset your password</h1>
        <p class="muted">Enter the email associated with your account. We'll send you a secure reset link.</p>

        <form asp-action="ForgotPassword" method="post" class="form-stack">
            <div asp-validation-summary="ModelOnly" class="form-errors"></div>

            <div class="form-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button class="btn btn-primary full" type="submit">Send reset link</button>
        </form>

        <div class="auth-foot">
            <a asp-action="Login">← Back to sign in</a>
        </div>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
