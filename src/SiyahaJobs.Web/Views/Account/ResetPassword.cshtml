@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Set new password";
}
<section class="auth-wrap">
    <div class="auth-card">
        <a asp-controller="Home" asp-action="Index" class="auth-logo">
            <span class="logo-green">Siyaha</span><span class="logo-navy">Jobs</span><span class="logo-dot">.jo</span>
        </a>
        <h1>Set a new password</h1>
        <p class="muted">Choose a strong new password — at least 6 characters.</p>

        <form asp-action="ResetPassword" method="post" class="form-stack">
            <div asp-validation-summary="All" class="form-errors"></div>

            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div class="form-field">
                <label asp-for="NewPassword"></label>
                <input asp-for="NewPassword" />
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button class="btn btn-primary full" type="submit">Update password</button>
        </form>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
