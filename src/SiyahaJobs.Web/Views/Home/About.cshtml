@{
    ViewData["Title"] = "About";
}
<section class="page-hero">
    <div class="container">
        <h1>About SiyahaJobs</h1>
        <p>
            SiyahaJobs is Jordan's dedicated career platform for the tourism and
            hospitality sector — connecting talented professionals with the country's
            leading hotels, restaurants, tour operators and travel companies.
        </p>
    </div>
</section>

<section class="container">
    <div class="about-grid">
        <div class="card">
            <h3>Our mission</h3>
            <p>
                Build Jordan's most trusted bridge between tourism employers and
                the next generation of hospitality talent.
            </p>
        </div>
        <div class="card">
            <h3>Our vision</h3>
            <p>
                A thriving tourism industry fueled by skilled, motivated people who
                grow their careers with confidence.
            </p>
        </div>
        <div class="card">
            <h3>What we offer</h3>
            <ul>
                <li>Verified employers and real opportunities</li>
                <li>Professional CV tools and profile visibility</li>
                <li>Industry-aligned career standards and pathways</li>
                <li>Insights on demand, salaries and seasonal trends</li>
            </ul>
        </div>
    </div>
</section>
