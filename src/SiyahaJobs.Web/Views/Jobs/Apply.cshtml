@model ApplyJobViewModel
@{
    ViewData["Title"] = $"Apply — {Model.JobTitle}";
}
<section class="container narrow" style="padding: 48px 24px;">
    <a asp-action="Details" asp-route-id="@Model.JobId" class="back-link">← Back to job</a>
    <h1>Apply for @Model.JobTitle</h1>
    <p class="muted">at @Model.CompanyName</p>

    <div class="card">
        <form asp-action="Apply" method="post" enctype="multipart/form-data" class="form-grid">
            <input type="hidden" asp-for="JobId" />

            <div asp-validation-summary="ModelOnly" class="form-errors"></div>

            <div class="form-field full">
                <label asp-for="CoverLetter"></label>
                <textarea asp-for="CoverLetter" rows="6" placeholder="Why are you a great fit for this role?"></textarea>
                <span asp-validation-for="CoverLetter" class="field-error"></span>
            </div>

            <div class="form-field full">
                <label asp-for="CvFile"></label>
                <input asp-for="CvFile" type="file" accept=".pdf,.doc,.docx" />
                <span class="muted">Upload a new CV or we'll use the one on your profile (PDF, DOC, DOCX up to 5 MB).</span>
                <span asp-validation-for="CvFile" class="field-error"></span>
            </div>

            <div class="full form-actions">
                <a asp-action="Details" asp-route-id="@Model.JobId" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary">Submit application</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
